# Required only if you want GPT-generated answers.
# Without this key, the backend still runs in safe extractive fallback mode.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.1-chat-latest

# API settings
APP_NAME=MathPath AI Chatbot Backend
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://www.mathpath.in,https://mathpath.in

# Local CSV storage
LEADS_CSV_PATH=storage/leads.csv
CHAT_LOG_CSV_PATH=storage/chat_logs.csv

# Admin endpoints: set a strong private key before deployment.
ADMIN_API_KEY=change_this_admin_key

# Optional: Send every lead to Make/Zapier/Pabbly/Google Apps Script webhook.
LEAD_WEBHOOK_URL=

# Optional: Supabase REST storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=mathpath_leads

# Retrieval settings
TOP_K=5
MIN_RETRIEVAL_SCORE=0.08
