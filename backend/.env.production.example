APP_NAME=MathPath AI Chatbot Backend
APP_ENV=production
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Add frontend deployment URL and MathPath website domains.
ALLOWED_ORIGINS=https://your-vercel-chatbot-url.vercel.app,https://www.mathpath.in,https://mathpath.in

TOP_K=5
MIN_RETRIEVAL_SCORE=0.08

# Local CSV storage paths on the server.
LEADS_CSV_PATH=storage/leads.csv
CHAT_LOG_CSV_PATH=storage/chat_logs.csv

# Admin key used for /admin/leads and export endpoints.
ADMIN_API_KEY=replace_with_a_long_random_admin_key

# Optional integrations. Leave blank if unused.
LEAD_WEBHOOK_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=mathpath_leads
